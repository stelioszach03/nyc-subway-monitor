# Create the .gitignore file
cat > .gitignore << 'EOF'
# Dependencies
node_modules
.pnp
.pnp.js

# Build output
dist
build
web/dist

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
convert.js
convert.cjs
tmp/

# Cache
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Generated ML model files
/services/ml/models/*
!/services/ml/models/.gitkeep

# Data files
stops.txt

# Keep the generated GeoJSON in version control
!public/subway-stations.geojson
EOF